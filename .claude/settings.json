{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(shellcheck:*)",
      "Bash(gitleaks:*)",
      "Bash(find plugins:*)",
      "Bash(bash plugins/shipyard/hooks/tests/:*)",
      "Bash(bash plugins/shipyard/scripts/tests/:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh search:*)",
      "Bash(gh label list:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Bash(git commit *--no-verify*)",
      "Bash(git push *--no-verify*)",
      "Bash(git commit *--no-gpg-sign*)",
      "Bash(git commit *--no-commit-hooks*)"
    ]
  }
}
