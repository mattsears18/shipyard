{
  "name": "app-audits",
  "version": "0.15.1",
  "description": "Audit web + mobile apps across UX, performance, security, accessibility, and more — autonomously files GitHub issues for every finding, and burns them down with /do-work.",
  "author": {
    "name": "Matt Sears",
    "email": "mattsears18@gmail.com"
  },
  "homepage": "https://github.com/mattsears18/claude-plugins",
